# sccache local configuration — copy to local.env and fill in your values.
# local.env is gitignored and must never be committed to the repository.
#
# Usage (Git Bash / Linux):   source dev/runtime/local.env
# Usage (PowerShell):         Get-Content dev/runtime/local.env | ForEach-Object { if ($_ -match '^([^#][^=]*)=(.*)$') { [System.Environment]::SetEnvironmentVariable($Matches[1].Trim(), $Matches[2].Trim()) } }
#
# IMPORTANT — sccache server restart:
#   The sccache server daemon reads SCCACHE_REDIS at startup only.
#   If the server is ever restarted (sccache --stop-server / --start-server),
#   you MUST set SCCACHE_REDIS before starting the server, otherwise it falls
#   back to local disk and loses the Redis backend.
#   Always: (1) source local.env, (2) sccache --stop-server, (3) sccache --start-server

RUSTC_WRAPPER=sccache
SCCACHE_REDIS=redis://YOUR_REDIS_HOST
